###EXCEPTIONS: help you you deal with errors in code in a clean manner.
##Example below will cause an error becuase you can not devide by zero:
# x = 10 / 0

##The code above results in a <ZeroDevisionError: division by zero> the code below provides
## a way to group the error and present a better expereince for the user.
# try:
#     x = 10 / 0
# except:
#     print("Don't be silly!")

##you can write exceptions that handle different kinds of errors and group them togther.
try:
    answer = input("What should I devide 10 by?: ")
    num = int(answer)
    print(int((10 / num)))
except ZeroDivisionError as e:
    print("You can't devide by zero!")
except ValueError as e:
    print("You didn't provide a vlaid number!")
    print(e)
finally:
    print("This code is goelden!")


